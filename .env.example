# Supabase — สร้างไฟล์ .env จากตัวอย่างนี้ (ไฟล์ .env ไม่ถูก push ขึ้น Git)
# URL: Supabase → Settings → General → Project URL
# Key: Supabase → Settings → API Keys → Publishable key (sb_publishable_...)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# Optional — override QR link (defaults to production /audience when on localhost)
# VITE_AUDIENCE_URL=https://stat-fan-game.vercel.app/audience
